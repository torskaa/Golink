generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("AFFILIATE")
  taxId         String?
  taxCountry    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  workspaces Workspace[]
  brands     Brand[]
  leads      Lead[]
  payouts    Payout[]
  joinRequests JoinRequest[]
}

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  customDomain String?
  domainVerified Boolean @default(false)
  userId       String
  payoutHoldingPeriod Int       @default(0)
  minimumPayoutAmount  Float     @default(0)
  payoutFeeConfig      String    @default("{}")
  integrations         String    @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  partners  Partner[]
  links     Link[]
  folders   Folder[]
  tags      Tag[]
  domains   Domain[]
  apiKeys   ApiKey[]
  webhooks  Webhook[]
  payouts   Payout[]
}

model Domain {
  id          String   @id @default(cuid())
  slug        String   @unique
  verified    Boolean  @default(false)
  primary     Boolean  @default(false)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links       Link[]
  createdAt   DateTime @default(now())
}

model Brand {
  id          String   @id @default(cuid())
  companyName String
  websiteUrl  String?
  isVerified  Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  products  Product[]
}

model Campaign {
  id             String  @id @default(cuid())
  workspaceId    String
  brandId        String?
  title          String
  description    String?
  commissionRate Float   @default(10.0)
  rewardType     String  @default("percentage")
  rewardConfig   String  @default("{}")
  targetUrl      String?
  status         String  @default("DRAFT")
  isPublic       Boolean @default(false)
  customerDiscount Float  @default(0)
  customerDiscountType String @default("percent")
  customerDiscountDuration String?
  partnerReferralReward String @default("{}")
  programLandingPage    String @default("{}")
  applicationForm       String @default("{}")
  payoutHoldingPeriod Int    @default(0)
  minimumPayoutAmount  Float  @default(0)
  riskSettings         String @default("{}")
  payoutFeeConfig      String @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand         Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  links         Link[]
  groups        PartnerGroup[]
  leads         Lead[]
  socialBounties SocialBounty[]
  rewardConditions RewardCondition[]
  joinRequests  JoinRequest[]
  products      CampaignProduct[]
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String?
  price       Float    @default(0)
  currency    String   @default("USD")
  imageUrl    String?
  productUrl  String?
  sku         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  campaigns   CampaignProduct[]
  links       Link[]
  clickEvents ClickEvent[]
}

model CampaignProduct {
  campaignId         String
  productId          String
  commissionOverride Float?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([campaignId, productId])
}

model PartnerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  campaignId  String
  rewardType  String   @default("percentage")
  rewardRate  Float    @default(10.0)
  rewardConfig String  @default("{}")
  customerDiscount Float  @default(0)
  customerDiscountType String @default("percent")
  customerDiscountDuration String?
  payoutHoldingPeriod Int    @default(0)
  minimumPayoutAmount  Float  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  partners Partner[]
}

model RewardCondition {
  id          String   @id @default(cuid())
  campaignId  String
  type        String   @default("geo")
  config      String   @default("{}")
  rewardType  String   @default("percentage")
  rewardRate  Float    @default(10.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children    Folder[] @relation("FolderTree")
  links       Link[]
  createdAt   DateTime @default(now())

  @@unique([workspaceId, name, parentId])
}

model Partner {
  id          String   @id @default(cuid())
  workspaceId String
  groupId     String?
  name        String
  email       String
  paypalEmail String?
  promptpayId String?
  stripeAccountId String?
  totalRevenue      Float   @default(0)
  totalPayouts      Float   @default(0)
  totalConversions  Int     @default(0)
  riskScore         Float   @default(0)
  status      String   @default("active")
  lastActiveAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  group     PartnerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  links     Link[]
}

model Link {
  id              String   @id @default(cuid())
  workspaceId     String
  domainId        String?
  folderId        String?
  campaignId      String?
  partnerId       String?
  productId       String?
  key             String
  url             String
  title           String?
  description     String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  clicks          Int      @default(0)
  uniqueClicks    Int      @default(0)
  conversions     Int      @default(0)
  revenue         Float    @default(0.0)
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  password        String?
  cloaked         Boolean  @default(false)
  ogImage         String?
  ogTitle         String?
  ogDescription   String?
  abTestUrl       String?
  abTestTraffic   Float    @default(50.0)
  deviceMobileUrl   String?
  deviceDesktopUrl  String?
  deviceTabletUrl   String?
  geoOverrides      String  @default("[]")
  deepLinkIos       String?
  deepLinkAndroid   String?
  customerDiscount Float   @default(0)
  customerDiscountType String @default("percent")
  customerDiscountDuration String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain       Domain?      @relation(fields: [domainId], references: [id], onDelete: SetNull)
  folder       Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  partner      Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  clickEvents  ClickEvent[]
  tags         LinkTag[]
  customerJourneyEvents CustomerJourneyEvent[]

  @@unique([workspaceId, key])
  @@index([key])
  @@index([folderId])
  @@index([campaignId])
  @@index([partnerId])
  @@index([productId])
}

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#2563eb")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links       LinkTag[]
  createdAt   DateTime @default(now())

  @@unique([workspaceId, name])
}

model LinkTag {
  linkId String
  tagId  String
  link   Link @relation(fields: [linkId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([linkId, tagId])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  hashedKey   String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Webhook {
  id          String   @id @default(cuid())
  url         String
  events      String   @default("[]")
  secret      String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClickEvent {
  id          String   @id @default(cuid())
  linkId      String
  productId   String?
  ip          String?
  country     String?
  city        String?
  referer     String?
  device      String?
  browser     String?
  os          String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  createdAt   DateTime @default(now())

  link    Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([linkId])
  @@index([createdAt])
  @@index([country])
  @@index([productId])
}

model CustomerJourneyEvent {
  id          String   @id @default(cuid())
  linkId      String
  customerEmail String?
  eventType   String
  eventData   String   @default("{}")
  amount      Float    @default(0)
  currency    String   @default("USD")
  createdAt   DateTime @default(now())

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([customerEmail])
}

model SocialBounty {
  id          String   @id @default(cuid())
  campaignId  String
  platform    String   @default("youtube")
  metric      String   @default("views")
  target      Int      @default(10000)
  reward      Float    @default(100)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Payout {
  id          String   @id @default(cuid())
  workspaceId String
  affiliateId String
  amount      Float
  currency    String   @default("USD")
  method      String   @default("stripe")
  status      String   @default("pending")
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  affiliate User      @relation(fields: [affiliateId], references: [id])
  invoice   Invoice?

  @@index([workspaceId])
  @@index([affiliateId])
}

model Invoice {
  id          String   @id @default(cuid())
  payoutId    String   @unique
  number      String
  periodStart DateTime
  periodEnd   DateTime
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending")
  pdfUrl      String?
  createdAt   DateTime @default(now())

  payout Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
}

model JoinRequest {
  id          String   @id @default(cuid())
  campaignId  String
  affiliateId String
  status      String   @default("PENDING")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  affiliate User     @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@unique([campaignId, affiliateId])
  @@index([campaignId])
  @@index([affiliateId])
}

model Lead {
  id              String   @id @default(cuid())
  campaignId      String?
  affiliateId     String?
  email           String
  companyName     String?
  status          String   @default("PENDING")
  stripeSessionId String?
  revenueAmount   Float    @default(0.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  affiliate User?     @relation(fields: [affiliateId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([affiliateId])
}

